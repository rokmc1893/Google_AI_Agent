# API server
API_HOST=127.0.0.1
API_PORT=8000
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Upload limits
MAX_UPLOAD_BYTES=10485760

# Phase 2 — Gemini LLM
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash
# true면 API 키 있을 때 LLM 사용, false면 Phase1 규칙 기반 fallback만
USE_LLM=true

# Phase 3 — RAG + 국가법령정보센터
LAW_API_KEY=
CHROMA_DIR=backend/data/chroma
EMBEDDING_MODEL=paraphrase-multilingual-MiniLM-L12-v2
USE_RAG=true

# Phase 5 — KPI SLA (seconds)
SCREEN_SLA_SECONDS=180

# Phase 7 — LangGraph StateGraph
USE_LANGGRAPH=true
