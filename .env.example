# API server
API_HOST=127.0.0.1
API_PORT=8000
# Add the deployed Vercel frontend URL before using the Railway backend in production.
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,https://your-vercel-app.vercel.app
DEMO_API_TOKEN=
# 프론트 개발 서버에서 보호된 API를 호출할 때 같은 값을 X-Demo-Token 헤더로 전송합니다.
VITE_DEMO_API_TOKEN=

# Upload limits
MAX_UPLOAD_BYTES=10485760
JOB_TTL_MINUTES=30
UPLOADS_PER_MINUTE=10
MAX_CONCURRENT_SCREENINGS=2

# Phase 2 — Gemini LLM
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash
# Railway/Gemini-only deployments should keep Ollama blank to avoid localhost retry delay.
OLLAMA_BASE_URL=
# true면 API 키 있을 때 LLM 사용, false면 Phase1 규칙 기반 fallback만
USE_LLM=true

# Phase 3 — RAG + 국가법령정보센터
LAW_API_KEY=
CHROMA_DIR=backend/data/chroma
EMBEDDING_MODEL=paraphrase-multilingual-MiniLM-L12-v2
USE_RAG=true

# Phase 5 — KPI SLA (seconds)
SCREEN_SLA_SECONDS=180

# Phase 7 — LangGraph StateGraph
USE_LANGGRAPH=true
